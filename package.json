{
  "name": "lightclaude",
  "productName": "Light Code",
  "version": "0.2.2",
  "description": "Light Code — a lightweight multi-terminal manager built for Claude Code power users",
  "main": "./out/main/index.js",
  "author": "Mikhail Aiman",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "rebuild": "electron-rebuild -f -w node-pty",
    "bytecode": "node scripts/build-bytecode.cjs",
    "dist": "electron-vite build && npm run bytecode && electron-builder"
  },
  "dependencies": {
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0",
    "bytenode": "^1.6.0",
    "electron-updater": "^6.8.9",
    "node-pty": "1.2.0-beta.14"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "@types/node": "^26.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "javascript-obfuscator": "^5.4.7",
    "typescript": "^6.0.3",
    "vite-plugin-javascript-obfuscator": "^3.1.0",
    "vitest": "^4.1.10"
  }
}
